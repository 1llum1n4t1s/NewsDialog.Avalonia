<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- primary ボタン: アクセント色背景 + 白文字 -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource News.AccentBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="12,4"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="MinWidth" Value="80"/>
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource News.AccentBrush}"/>
    <Setter Property="Opacity" Value="0.85"/>
  </Style>
  <Style Selector="Button.primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource News.AccentBrush}"/>
    <Setter Property="Opacity" Value="0.7"/>
  </Style>

  <!-- danger ボタン: 緊急アクション用 (赤背景 + 白文字) -->
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{DynamicResource News.ErrorBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="12,4"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="MinWidth" Value="80"/>
  </Style>
  <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource News.ErrorBrush}"/>
    <Setter Property="Opacity" Value="0.85"/>
  </Style>
  <Style Selector="Button.danger:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource News.ErrorBrush}"/>
    <Setter Property="Opacity" Value="0.7"/>
  </Style>

  <!-- カテゴリ タブ (横並びチップ) -->
  <Style Selector="ListBox.tabs">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
  </Style>
  <Style Selector="ListBox.tabs ListBoxItem">
    <Setter Property="Padding" Value="10,4"/>
    <Setter Property="Margin" Value="0,0,4,8"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Foreground" Value="{DynamicResource News.SubtleForegroundBrush}"/>
  </Style>
  <Style Selector="ListBox.tabs ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource News.AccentBrush}"/>
    <Setter Property="TextElement.Foreground" Value="White"/>
    <Setter Property="CornerRadius" Value="12"/>
  </Style>

  <!-- お知らせ一覧 -->
  <Style Selector="ListBox.newslist">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
  </Style>
  <Style Selector="ListBox.newslist ListBoxItem">
    <Setter Property="Padding" Value="2"/>
    <Setter Property="Margin" Value="0,1"/>
    <Setter Property="CornerRadius" Value="6"/>
  </Style>
  <Style Selector="ListBox.newslist ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource News.SelectionBrush}"/>
    <Setter Property="CornerRadius" Value="6"/>
  </Style>

  <!-- 緊急カード -->
  <Style Selector="Border.emergencyCard">
    <Setter Property="Background" Value="{DynamicResource News.CardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource News.ErrorBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Effect" Value="drop-shadow(0 4 20 #60000000)"/>
  </Style>

</Styles>
