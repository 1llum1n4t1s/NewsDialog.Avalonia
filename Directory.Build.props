<Project>
  <PropertyGroup>
    <Version>0.1.0</Version>
    <Authors>ゆろち</Authors>
    <Copyright>Copyright (c) 2026 ゆろち</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/1llum1n4t1s/NewsDialog.Avalonia</PackageProjectUrl>
    <RepositoryUrl>https://github.com/1llum1n4t1s/NewsDialog.Avalonia</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageOutputPath>$(MSBuildThisFileDirectory)artifacts</PackageOutputPath>
    <PackageTags>avalonia;news;announcements;dialog;mvvm;webview</PackageTags>

    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <!-- SourceLink / Deterministic build -->
    <DebugType>portable</DebugType>
    <Deterministic>true</Deterministic>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>

    <!-- icon ファイルが存在する場合のみ参照 (placeholder 運用) -->
    <PackageIcon Condition="Exists('$(MSBuildThisFileDirectory)icon/app_icon.png')">icon.png</PackageIcon>
  </PropertyGroup>

  <!-- IsPackable=true のプロジェクトにのみ README / LICENSE を同梱 -->
  <ItemGroup Condition="'$(IsPackable)' == 'true'">
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="\" Visible="false" />
    <None Include="$(MSBuildThisFileDirectory)LICENSE" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <ItemGroup Condition="'$(IsPackable)' == 'true' AND Exists('$(MSBuildThisFileDirectory)icon/app_icon.png')">
    <None Include="$(MSBuildThisFileDirectory)icon/app_icon.png" Pack="true" PackagePath="icon.png" Visible="false" />
  </ItemGroup>
</Project>
